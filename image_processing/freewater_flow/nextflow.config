process {
    executor = 'slurm'
    queue    = 'main'
    clusterOptions = '--account=jasonkru_1564'
    publishDir = {"./results/$sid/$task.process"}
    errorStrategy = { task.attempt <= 3 ? 'retry' : 'ignore' }
    maxRetries = 3
    maxErrors = -1
    scratch = false
    stageInMode = 'symlink'
    stageOutMode = 'copy'
    tag = { "$sid" }
    afterScript = 'sleep 1'

    // Ensure container PATH resolves scilpy CLI and uses venv python with AMICO
    containerOptions = "--env PATH=/opt/venvs/scilpy/bin:/scilpy/src/scilpy/cli:/usr/local/bin:/usr/bin:/bin"
}

params {
    output_dir="./results/"
    nb_threads=1
    para_diff=1.5e-3
    iso_diff=3e-3
    perp_diff_min=0.1e-3
    perp_diff_max=0.7e-3
    lambda1=0
    lambda2=0.25
    b_thr=40
}

if(params.output_dir) {
    process.publishDir = {"$params.output_dir/$sid/$task.process"}
}

singularity.autoMounts=true

// Allow passing selected env vars if set in the launcher (optional)
envWhitelist = 'APPTAINERENV_*,SINGULARITYENV_*'

// Per-process resource tuning for SLURM
process {
    withName: Compute_Kernel {
        cpus = 1
        memory = '24 GB'
        time = '01:00:00'
        clusterOptions = '--account=jasonkru_1564 --mem=24G'
    }

    withName: Compute_FreeWater {
        cpus = params.nb_threads
        memory = '12 GB'
        time = '04:00:00'
        clusterOptions = '--account=jasonkru_1564 --mem=12G'
    }

    withName: FW_Corrected_Metrics {
        cpus = 3
        memory = '8 GB'
        time = '01:00:00'
        clusterOptions = '--account=jasonkru_1564 --mem=8G'
    }
}

// Submission throttling (optional)
executor.queueSize = 100
